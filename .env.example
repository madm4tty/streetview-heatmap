# Street View Heatmap - Environment Configuration
# ================================================
# Copy this file to .env and fill in your values

# Google Maps API Key (required)
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# The Street View Metadata API is FREE with unlimited requests
GOOGLE_MAPS_API_KEY=your_api_key_here

# Database Configuration
# -----------------------
# Option 1: SQLite (default) - for local development / CLI tool
# Defaults to "metadata.db" if not set
# HEATMAP_DB=metadata.db

# Option 2: PostgreSQL with PostGIS - for web backend and UK-wide coverage
# Format: postgresql://user:password@host:port/database
# Local docker-compose:
DATABASE_URL=postgresql://streetview:streetview_dev@localhost:5432/streetview
#
# Production example:
# DATABASE_URL=postgresql://user:password@your-server.com:5432/streetview

# Web API Configuration
# ---------------------
# API key for write operations (POST /api/update/trigger, POST /api/config)
# Used in X-API-Key header
API_KEY=your_secure_api_key_here

# Alternative: GitHub Codespaces secret name
# If running in GitHub Codespaces, GMAPS_APIKEY will be auto-detected
# GMAPS_APIKEY is automatically mapped to GOOGLE_MAPS_API_KEY
